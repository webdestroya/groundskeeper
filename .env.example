# Database connection string.
# Supports plain URLs, SSM parameter paths (ssm:/path or /path), and
# Secrets Manager ARNs (arn:aws:secretsmanager:...).
# Also accepted: GROUNDSKEEPER_DATABASE_URL, GK_DATABASE_URL
DATABASE_URL=

# GitHub personal access token (used by the `pull` command to fetch migrations
# from a private repository).
# Also accepted: GROUNDSKEEPER_GITHUB_TOKEN
GITHUB_TOKEN=
